{%- macro AnnotationProcessors(func, annotation_processors) -%}
{%-     if annotation_processors|length -%}
{%-         set first_ap = annotation_processors|first -%}
{%-         set annotation_processors = annotation_processors|unique -%}
{%-         set lomboks = annotation_processors|selectattr('jar', 'startsWith', LOMBOK_PATH) -%}
{%-         set lombok_jars = lomboks|map(attribute='jar')|unique -%}
{%-         set nolomboks = annotation_processors|rejectattr('jar', 'startsWith', LOMBOK_PATH) -%}
{%-         set nolombok_jars = nolomboks|map(attribute='jar')|unique -%}
{%-         if lomboks|length -%}
{%-             for lombok_jar in lombok_jars -%}
{%-                 set annotation_processor = lomboks|selectattr('jar', 'eq', lombok_jar)|first -%}
{%-                 set parts = rsplit(annotation_processor.jar, "/", 4) %}
    {{ func }}("{{ parts[0]|replace("contrib/java/", "")|replace("/", ".") }}:{{ parts[1] }}:{{ parts[2] }}")
{%-             endfor -%}
{%-         endif -%}
{%-         if nolomboks|length -%}
{%-             for nolombok_jar in nolombok_jars -%}
{%-                 set annotation_processor = nolomboks|selectattr('jar', 'eq', nolombok_jar)|first -%}
{%-                 if [annotation_processor.jar]|select('startsWith', 'contrib/java/')|length -%}
{#-                     Contrib AP, use by classpath -#}
{%-                     set parts = rsplit(annotation_processor.jar, "/", 4) %}
    {{ func }}("{{ parts[0]|replace("contrib/java/", "")|replace("/", ".") }}:{{ parts[1] }}:{{ parts[2] }}")
{%-                 else -%}
{#-                     Has handmade AP, put all APs as jars in one list #}
    {{ func }}(files(listOf(
{%-                     if annotation_processor.deps|length -%}
{%-                         for annotation_processor_dep in annotation_processor.deps %}
        {{ PatchRoots(output_root + "/" + annotation_processor_dep, false, "", true) }},
{%-                         endfor -%}
{%-                     endif %}
        {{ PatchRoots(output_root + "/" + annotation_processor.jar, false, "", true) }},
    )))
{%-                 endif %}
{%-             endfor %}
{%-         endif -%}
{%-     endif -%}
{%- endmacro -%}

{%- macro Kapts(func, kapts, file_jars, alltests_file_jars) -%}
{%-     if kapts|length -%}
{%-         set kapt_first = kapts|first -%}
{%-         set kapt_jars = kapts|map(attribute='jar')|unique -%}
{%-         for kapt_jar in kapt_jars -%}
{%-             set kapt = kapts|selectattr('jar', 'eq', kapt_jar)|first -%}
{%-             if (kapt_jar in file_jars) or (kapt_jar in alltests_file_jars) -%}
{#-                 found KAPT jar in depends => use kapt as jar #}
    {{ func }}(files(listOf(
{%-                if kapt.deps|length -%}
{%-                    for kapt_dep in kapt.deps %}
        "$output_root/{{ kapt_dep }}",
{%-                    endfor -%}
{%-                endif %}
        "$output_root/{{ kapt_jar }}",
    )))
{%-             else -%}
{#-                 no in depends jar => use KAPT as project() -#}
{%-                 set classpath = 'project(":' + dirname(kapt_jar)|replace("/", ":") + '")' -%}
{%-                 include "[generator]/patch_classpath.jinja" %}
    {{ func }}({{ classpath }})
{%-             endif -%}
{%-         endfor -%}
{%-     endif -%}
{%- endmacro -%}


{%- macro RunsConfigurations(current_target) -%}
{%-     if current_target.runs|length -%}
{%-         for run in current_target.runs -%}
{%-             set classpath = run.classpath -%}
{%-             if classpath != "" and classpath|replace('.cplst') == classpath -%}
{#-                 Project in exported classpath -#}
{%-                 set classpath = '":' + classpath|replace("/", ":") + '"' -%}
{%-                 include "[generator]/patch_classpath.jinja" %}
    {{ varprefix }}{{ run['_object_index'] }}Classpath(project({{ classpath }}))
{%-             endif -%}
{%-         endfor -%}
{%      endif -%}
{%- endmacro -%}

{%- macro TargetsConfigurations() -%}
{%-     if target is defined -%}
{%-         set current_target = target -%}
{#-         Main target codegen -#}
{%-         set varprefix = MAIN_VARPREFIX -%}
{{ RunsConfigurations(current_target) }}
{%-     endif -%}
{%-     if extra_targets|length -%}
{%-         for current_target in extra_targets -%}
{#-             TestN target codegen -#}
{%-             set varprefix = "test" + loop.index0|tojson + "Codegen" -%}
{{ RunsConfigurations(current_target) }}
{%-         endfor -%}
{%-     endif -%}
{%- endmacro -%}

{%- macro AddFileJars(implementation, file_jars) -%}
{%-     if file_jars|length %}
    {{ implementation }}(files(listOf(
{%-         for file_jar in file_jars %}
        "$output_root/{{ file_jar }}",
{%-         endfor %}
    )))
{%-     endif -%}
{%- endmacro -%}

{%- macro AddNonFileDeps(libraries, file_classpaths, implementationFunc, apiFunc) -%}
{%-     for library in libraries -%}
{%-         set classpath = library.classpath -%}
{%-         if library.type == "ejlibrary" or library.type == "swigdll" %}
{#-             External java library or DLL_JAVA #}
    {{ implementationFunc }}(files("$output_root/{{ library.jar }}"))
{%-         elif classpath and file_classpaths|select('eq', classpath)|length == 0 -%}
{%-             if library.type == "contrib" and library.jar and classpath|replace('project(":', '') != classpath %}
{#-                 Contrib in exported arcadia folders #}
    {{ implementationFunc }}(files("$output_root/{{ library.jar }}"))
{%-             else -%}
{%-                 if classpath|replace('"','') == classpath -%}
{%-                     set classpath = '"' + classpath + '"' -%}
{%-                 endif -%}
{%-                 include "[generator]/patch_classpath.jinja" -%}
{%-                 if library.type != "contrib" -%}
{%-                     if library.testdep -%}
{%-                         set classpath = '":' + library.testdep | replace("/", ":") + '"' -%}
{%-                         include "[generator]/patch_classpath.jinja" %}
    {{ implementationFunc }}(project(path = {{ classpath }}, configuration = "testArtifacts"))
{%-                     else %}
    {{ implementationFunc }}({{ classpath }})
{%-                     endif -%}
{%-                 else %}
    {{ apiFunc }}({{ classpath }})
{%-                 endif -%}
{%-                 if library.excludes.consumer|length and not build_contribs -%} {
{%-                     for exclude in library.excludes.consumer if exclude.classpath -%}
{%-                         set classpath = exclude.classpath|replace('"','') -%}
{%-                         set classpath_parts = split(classpath, ':') -%}
{%-                         if (classpath_parts[0] != "") and (classpath_parts[1] != "") %}
        exclude(group = "{{ classpath_parts[0] }}", module = "{{ classpath_parts[1] }}")
{%-                         endif -%}
{%-                     endfor %}
    }
{%-                 endif -%}
{%-             endif -%}
{%-         endif -%}
{%-     endfor -%}
{%- endmacro -%}

{%- set file_deps = target.consumer|selectattr('classpath')|selectattr('jar')|selectattr('prebuilt', 'eq', true) -%}
{%- if not build_contribs -%}
{%-     set file_deps = file_deps|selectattr('type', 'ne', 'contrib') -%}
{%- endif -%}
{%- set file_classpaths = file_deps|map(attribute='classpath')|unique -%}
{%- set file_jars = file_deps|map(attribute='jar')|unique -%}
{%- set target_jars = target.consumer|selectattr('jar')|map(attribute='jar') -%}

{%- set alltests_file_deps = extra_targets|selectattr('consumer')|map(attribute='consumer')|sum|selectattr('classpath')|selectattr('jar')|selectattr('prebuilt', 'eq', true) -%}
{%- if not build_contribs -%}
{%-     set alltests_file_deps = alltests_file_deps|selectattr('type', 'ne', 'contrib') -%}
{%- endif -%}
{%- set alltests_file_jars = alltests_file_deps|map(attribute='jar')|unique -%}

{%- if target is defined or with_test_errorprones|length or with_errorprone or with_kapt or with_test_kapt or file_jars|length or target.consumer|length or (proto_template and (prepareProtosTask or extractLibrariesProtosTask)) %}
dependencies {
{%-     if with_test_errorprones|length or with_errorprone -%}
{%-         set errorprones = with_test_errorprones -%}
{%-         if with_errorprone -%}
{%-             set errorprones = errorprones + [with_errorprone] -%}
{%-         endif -%}
{%-         for errorprone in errorprones|unique -%}
{%-             set parts = split(errorprone, '.') -%}
{%-             if parts[1]|int < 23 -%}
{#-                 ErrorProne 2.7.1 / 2.10.0 / 2.18.0 crashed with IndexOutOfBoundsException on generated code, 2.23.0	- works good -#}
{%-                 set errorprone = '2.23.0' -%}
{%-             endif %}
    errorprone("com.google.errorprone:error_prone_core:{{ errorprone }}")
{%-         endfor -%}
{%-     endif -%}
{#- glue -#}
{{ AnnotationProcessors("annotationProcessor", target.use_annotation_processors) }}
{%-     if with_kapt -%}
{{ Kapts("kapt", target.kapt.kapts, file_jars, alltests_file_jars) }}
{%-     endif -%}
{%-     if with_test_kapt -%}
{%-         set test_kapts = extra_targets|selectattr('with_kapt', 'eq', true)|selectattr('kapt')|map(attribute='kapt')|selectattr('kapts')|map(attribute='kapts')|sum -%}
{{ Kapts("kaptTest", test_kapts, file_jars, alltests_file_jars) }}
{%-     endif -%}
{{ AddNonFileDeps(target.consumer, file_classpaths, "implementation", "api") }}
{%-     if file_jars|length -%}
{{ AddFileJars('implementation', file_jars) }}
{%-     endif -%}

{%-     if proto_template -%}
{%-         if prepareProtosTask %}
    protobuf(files(prepareMainProtos))
{%-         endif %}
{%-         if extractLibrariesProtosTask %}
    implementation(files(prepareMainIncludeProtos))
{%-         endif %}
{%-     endif %}
}
{%- endif -%}

{%- if all_targets|selectattr('runs')|length %}
dependencies {
{{ TargetsConfigurations() }}
}
{%- endif -%}

{%- if extra_targets|length -%}
{%-     if named_tests -%}
{%-         for extra_target in extra_targets %}

dependencies {
{%-             set testname = SourceSetName(extra_target) -%}
{%-             if extra_target.use_annotation_processors|length -%}
{%-                 if testname == NS_TEST -%}
{%-                     set testAnnotationProcessor = 'testAnnotationProcessor' -%}
{%-                 else -%}
{%-                     set testAnnotationProcessor = '"' + testname + 'AnnotationProcessor' + '"' -%}
{%-                 endif -%}
{{ AnnotationProcessors(testAnnotationProcessor, extra_target.use_annotation_processors) }}
{%-             endif -%}
{%-             if extra_target.consumer -%}
{%-                 set test_file_deps = extra_target.consumer|selectattr('classpath')|selectattr('jar')|selectattr('prebuilt', 'eq', true) -%}
{%-                 if not build_contribs -%}
{%-                     set test_file_deps = test_file_deps|selectattr('type', 'ne', 'contrib') -%}
{%-                 endif -%}
{%-                 set test_file_classpaths = test_file_deps|map(attribute='classpath')|unique -%}
{%-                 set test_file_jars = test_file_deps|map(attribute='jar')|unique -%}
{%-                 if testname == NS_TEST -%}
{#-                     testImplementation already consists all main implemenation dependencies -#}
{%-                     set main_file_jars = [] -%}
{%-                     set test_file_jars = test_file_jars|reject("in", file_jars) -%}
{%-                 else -%}
{%-                     set main_file_jars = test_file_jars|select("in", file_jars) -%}
{%-                     set test_file_jars = test_file_jars|reject("in", main_file_jars) -%}
{%-                 endif -%}
{%-                 set testImplementation = testname + 'Implementation' -%}
{{ AddNonFileDeps(extra_target.consumer|rejectattr('jar', 'in', target_jars), test_file_classpaths, testImplementation, testImplementation) }}
{#-
                    In sem-graph for each target firstly appended direct peers, then it transitive peers.
                    But direct and transitive peers may be in wrong order, we can't order it right here, this must do yexport.
                    Try do simple optimization - firstly add test jars exists in main jars, then add only test jars.
                    This is not best order, but best of bads.
-#}
{%-                 if main_file_jars|length -%}
{#-                     Firstly add test jars, exists in main jars -#}
{{ AddFileJars(testImplementation, main_file_jars) }}
{%-                 endif -%}
{%-                 if test_file_jars|length -%}
{#-                     Then add only tests jars -#}
{{ AddFileJars(testImplementation, test_file_jars) }}
{%-                 endif -%}
{%-             endif %}
}
{%-         endfor %}
{%      else %}

dependencies {
{%-         set use_annotation_processors = extra_targets|selectattr('use_annotation_processors')|map(attribute='use_annotation_processors')|sum -%}
{%-         if use_annotation_processors|length -%}
{{ AnnotationProcessors('testAnnotationProcessor', use_annotation_processors) }}
{%-         endif -%}
{%-         set alltests_file_classpaths = alltests_file_deps|map(attribute='classpath')|unique -%}
{{ AddNonFileDeps(extra_targets|selectattr('consumer')|map(attribute='consumer')|sum|rejectattr('jar', 'in', target_jars), alltests_file_classpaths, 'testImplementation', 'testImplementation') }}
{#-         testImplementation already consists all main implemenation dependencies -#}
{%-         set alltests_file_jars = alltests_file_jars|reject("in", file_jars) -%}
{%-         if alltests_file_jars|length -%}
{{ AddFileJars('testImplementation', alltests_file_jars) }}
{%-         endif %}
}
{%      endif -%}
{%- endif -%}
