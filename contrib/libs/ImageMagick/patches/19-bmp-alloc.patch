revision: 4194105

    RTHUBDUTY-8 fixed too big memory allocation in imagemagick

    Pull-request for branch users/izetag/RTHUBDUTY-8

    REVIEW: 603388

--- a/coders/bmp.c
+++ b/coders/bmp.c
@@ -1145,7 +1145,16 @@ static Image *ReadBMPImage(const ImageInfo *image_info,ExceptionInfo *exception)
     if ((BMPOverflowCheck(image->rows,extent) != MagickFalse) ||
         (BMPOverflowCheck(extent,sizeof(*pixels)) != MagickFalse))
       ThrowReaderException(ResourceLimitError,"MemoryAllocationFailed");
-    pixel_info=AcquireVirtualMemory(image->rows,extent*sizeof(*pixels));
+    size_t needed_memory_size= image->rows * extent * sizeof(*pixels);
+    /*
+      It's a workaround for specific allocators
+      which fail to return NULL
+      if memory allocation has been failed
+    */
+    if (needed_memory_size > (16ULL << 30))
+        pixel_info=(MemoryInfo *) NULL;
+    else
+        pixel_info=AcquireVirtualMemory(image->rows,extent*sizeof(*pixels));
     if (pixel_info == (MemoryInfo *) NULL)
       ThrowReaderException(ResourceLimitError,"MemoryAllocationFailed");
     pixels=(unsigned char *) GetVirtualMemoryBlob(pixel_info);
@@ -2121,7 +2130,16 @@ static MagickBooleanType WriteBMPImage(const ImageInfo *image_info,Image *image)
     if ((BMPOverflowCheck(image->rows,extent) != MagickFalse) ||
         (BMPOverflowCheck(extent,sizeof(*pixels)) != MagickFalse))
       ThrowWriterException(ImageError,"WidthOrHeightExceedsLimit");
-    pixel_info=AcquireVirtualMemory(image->rows,extent*sizeof(*pixels));
+    size_t needed_memory_size= image->rows * extent * sizeof(*pixels);
+    /*
+      It's a workaround for specific allocators
+      which fail to return NULL
+      if memory allocation has been failed
+    */
+    if (needed_memory_size > (16ULL << 30))
+        pixel_info=(MemoryInfo *) NULL;
+    else
+        pixel_info=AcquireVirtualMemory(image->rows,extent*sizeof(*pixels));
     if (pixel_info == (MemoryInfo *) NULL)
       ThrowWriterException(ResourceLimitError,"MemoryAllocationFailed");
     pixels=(unsigned char *) GetVirtualMemoryBlob(pixel_info);

