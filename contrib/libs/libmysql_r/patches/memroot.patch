destroy mem_root state after mysql_library_init() has initialized it when
it is called from another global initializer.

--- a/sql-common/client_plugin.cc
+++ b/sql-common/client_plugin.cc
@@ -106,3 +106,4 @@
 static bool initialized = 0;
-static MEM_ROOT mem_root;
+static MEM_ROOT *mem_root_ptr;
+#define mem_root (*mem_root_ptr)
 
@@ -330,2 +331,3 @@
                    MY_MUTEX_INIT_SLOW);
+  mem_root_ptr = new MEM_ROOT;
   init_alloc_root(key_memory_root, &mem_root, 128, 128);
@@ -370,2 +372,3 @@
   free_root(&mem_root, MYF(0));
+  delete mem_root_ptr;
   mysql_mutex_destroy(&LOCK_load_client_plugin);
