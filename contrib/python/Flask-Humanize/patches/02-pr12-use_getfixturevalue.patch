From 3bc04426424679ae3d1890efe741e8b418b6a6af Mon Sep 17 00:00:00 2001
From: danilaeremin <danilaeremin@users.noreply.github.com>
Date: Thu, 20 Jan 2022 19:08:13 +0300
Subject: [PATCH] Replace getfuncargvalue with getfixturevalue

There is not getfuncargvalue  function starting from pytest 5.1.

https://github.com/pytest-dev/pytest/issues/5180
---
 tests/conftest.py | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/tests/conftest.py b/tests/conftest.py
index c628fbf..3ddcba0 100644
--- contrib/python/Flask-Humanize/tests/conftest.py
+++ contrib/python/Flask-Humanize/tests/conftest.py
@@ -44,5 +44,5 @@ def h(request):
     if 'app' not in request.fixturenames:
         return
 
-    app = request.getfuncargvalue('app')
+    app = request.getfixturevalue('app')
     return Humanize(app)
