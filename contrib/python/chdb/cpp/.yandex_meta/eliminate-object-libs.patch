# Зачем нужен этот патч?
# Функции в CH регистрируются через макрос REGISTER_FUNCTION:
# https://github.com/ClickHouse/ClickHouse/blob/7c8e1a688a9b764f2fb1d1d28fe06b3dc014baa7/src/Common/register_objects.h#L33
# Этот макрос создает статическую переменную, в коснтрукторе которой и происходит регистрация в глобальной мапе.
# Поскольку никакие символы из исходников с реализацией функций не используются в других частях явно,
# линкер может выкинуть такие объектные файлы из сборки, в итоге функции не будут зарегистрированы,
# да и вообще не будут влинкованы в итоговый бинарник.
# Что бы гарантировать что все функции попадают в бинарник и регистрируются, в родной сборке CH
# библиотеки с функциями помечены как OBJECT, поэтому все объектные файлы линкуются напрямую в бинарник.
# yamaker не умеет работать с OBJECT библиотеками и структура проекта получается неправильной.
# (все такие исходники будут напрямую перечислены в SRCS в ya.make у PROGRAM).
# Поэтому используется такой хак:
# Заменяем OBJECT LIBRARY на обычную статическую. Тогда yamaker замечает эту библиотеку.
# Но теперь сборка неправильная: линкер будет выкидывать функции.
# Что бы это исправить мы добавляем руками GLOBAL для всех SRCS из этих библиотек.
diff --git a/src/Functions/Kusto/CMakeLists.txt b/src/Functions/Kusto/CMakeLists.txt
index 3c534905d22..6a4b1e41225 100644
--- a/src/Functions/Kusto/CMakeLists.txt
+++ b/src/Functions/Kusto/CMakeLists.txt
@@ -1,6 +1,6 @@
 include("${ClickHouse_SOURCE_DIR}/cmake/dbms_glob_sources.cmake")
 add_headers_and_sources(clickhouse_functions_kusto .)
-add_library(clickhouse_functions_kusto OBJECT ${clickhouse_functions_kusto_sources} ${clickhouse_functions_kusto_headers})
+add_library(clickhouse_functions_kusto ${clickhouse_functions_kusto_sources} ${clickhouse_functions_kusto_headers})
 target_link_libraries(clickhouse_functions_kusto PRIVATE dbms clickhouse_functions_gatherutils)
 
 if (OMIT_HEAVY_DEBUG_SYMBOLS)
diff --git a/src/Functions/URL/CMakeLists.txt b/src/Functions/URL/CMakeLists.txt
index ce9a430423b..f3ad7355b82 100644
--- a/src/Functions/URL/CMakeLists.txt
+++ b/src/Functions/URL/CMakeLists.txt
@@ -1,6 +1,6 @@
 include("${ClickHouse_SOURCE_DIR}/cmake/dbms_glob_sources.cmake")
 add_headers_and_sources(clickhouse_functions_url .)
-add_library(clickhouse_functions_url OBJECT ${clickhouse_functions_url_sources} ${clickhouse_functions_url_headers})
+add_library(clickhouse_functions_url ${clickhouse_functions_url_sources} ${clickhouse_functions_url_headers})
 target_link_libraries(clickhouse_functions_url PRIVATE dbms)
 set_source_files_properties(tldLookup.generated.cpp PROPERTIES COMPILE_FLAGS -Wno-shorten-64-to-32)
 
