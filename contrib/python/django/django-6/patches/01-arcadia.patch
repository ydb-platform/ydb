+def open_fixture(fixture_file, open_method, mode):
+    """
+    Yandex-specific
+    :return:
+    """
+    # try load from resource, in case of success - use correct open_method
+    content = resource.resfs_read(fixture_file)
+    if content is None:
+        return open_method(fixture_file, mode)
+    if has_bz2 and open_method == bz2.BZ2File:
+        return io.BytesIO(bz2.decompress(content))
+    f = io.BytesIO(content)
+    if open_method == open:
+        return f
+    if open_method == gzip.GzipFile:
+        return gzip.GzipFile(fileobj=f, mode=mode)
+    if open_method == SingleZipReader:
+        return SingleZipReader(f, mode=mode)
+    raise NotImplementedError("open_method {} for {} is not implemented".format(
+        open_method, fixture_file
+    ))
