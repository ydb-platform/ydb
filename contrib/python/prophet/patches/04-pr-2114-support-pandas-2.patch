From ba189833c3e15baf3d14313e23d42c1a9d3c00c0 Mon Sep 17 00:00:00 2001
From: Kha <nlhkha@gmail.com>
Date: Wed, 2 Feb 2022 20:19:28 +0200
Subject: [PATCH 1/2] Change deprecated `append` to `concat`

Pandas `frame.append` method is deprecated. Updating to the newer `pd.concat` method to prepare Prophet for future Pandas, and avoid generating warning log in runtime.
---
 python/prophet/forecaster.py | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/python/prophet/forecaster.py b/python/prophet/forecaster.py
index 2bb9242c6..734c3603f 100644
--- a/prophet/forecaster.py
+++ b/prophet/forecaster.py
@@ -893,7 +893,7 @@ def add_group_component(self, components, name, group):
         group_cols = new_comp['col'].unique()
         if len(group_cols) > 0:
             new_comp = pd.DataFrame({'col': group_cols, 'component': name})
-            components = components.append(new_comp)
+            components = pd.concat([components, new_comp])
         return components
 
     def parse_seasonality_args(self, name, arg, auto_disable, default_order):

