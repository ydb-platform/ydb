{% extends '//builtin/pycargo.ym' %}

{% block mod_name %}
_tiktoken
{% endblock %}

{% block current_version %}0.7.0{% endblock %}
{% block current_url %}https://github.com/openai/tiktoken/archive/refs/tags/{{self.version().strip()}}.tar.gz{% endblock %}

{% block patch_source %}
{{super()}}
sed -e 's|cdylib|staticlib|' -i Cargo.toml
{% endblock %}

{% block build_source %}
export PYO3_CROSS_PYTHON_VERSION=3.12
{{super()}}
{% endblock %}
