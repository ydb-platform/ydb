From cee01210a567305d32afbcfdc38f4db2300e52c5 Mon Sep 17 00:00:00 2001
From: Андрей Янковский <werat@yandex-team.ru>
Date: Thu, 29 Mar 2018 15:24:57 +0000
Subject: [PATCH] [uwsgi] Use loader directly

Plugin is not initialized in mule in lazy-apps mode
https://github.com/unbit/uwsgi/issues/1746

REVIEW: 424209

git-svn-id: svn+ssh://arcadia.yandex.ru/arc/trunk/arcadia/contrib/python@3522308 41d65440-b5be-11dd-afe3-b2e846d9b4f8
---
 uwsgi/plugins/python/python_plugin.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/plugins/python/python_plugin.c b/plugins/python/python_plugin.c
index 126786b94..c6c736582 100644
--- a/plugins/python/python_plugin.c
+++ b/plugins/python/python_plugin.c
@@ -1832,7 +1832,7 @@ int uwsgi_python_mule(char *opt) {
 		UWSGI_GET_GIL;
 		PyObject *result = NULL;
 		PyObject *arglist = Py_BuildValue("()");
-		PyObject *callable = up.loaders[LOADER_MOUNT](opt);
+		PyObject *callable = uwsgi_mount_loader(opt);
 		if (callable) {
 			result = PyObject_CallObject(callable, arglist);
 		}
-- 
2.19.2

