From 105d984539694d5af015b0fd72b48d8fa8143b8b Mon Sep 17 00:00:00 2001
From: Yuriy Chernyshov <thegeorg@yandex-team.ru>
Date: Mon, 8 Aug 2022 11:56:43 +0300
Subject: [PATCH] Modernize noexcept specifiers

---
 include/boost/qvm/config.hpp | 8 ++++++++
 include/boost/qvm/error.hpp  | 6 ++++--
 2 files changed, 12 insertions(+), 2 deletions(-)

diff --git a/include/boost/qvm/config.hpp b/include/boost/qvm/config.hpp
index 24871c8..fbe3d24 100644
--- a/include/boost/qvm/config.hpp
+++ b/include/boost/qvm/config.hpp
@@ -36,6 +36,14 @@
 #   define BOOST_QVM_INLINE_RECURSION BOOST_QVM_INLINE_OPERATIONS
 #endif
 
+#ifndef BOOST_QVM_NOEXCEPT
+#   if __cplusplus >= 201103L
+#       define BOOST_QVM_NOEXCEPT noexcept
+#   else
+#       define BOOST_QVM_NOEXCEPT throw()
+#   endif
+#endif
+
 #ifndef BOOST_QVM_CONSTEXPR
 #   if __cplusplus >= 201703L
 #       define BOOST_QVM_CONSTEXPR constexpr
diff --git a/include/boost/qvm/error.hpp b/include/boost/qvm/error.hpp
index 7e8f08d..e9dca5d 100644
--- a/include/boost/qvm/error.hpp
+++ b/include/boost/qvm/error.hpp
@@ -8,6 +8,8 @@
 
 #include <exception>
 
+#include <boost/qvm/config.hpp>
+
 namespace boost { namespace qvm {
 
 struct
@@ -15,12 +17,12 @@ struct
     std::exception
     {
     char const *
-    what() const throw()
+    what() const BOOST_QVM_NOEXCEPT
         {
         return "Boost QVM error";
         }
 
-    ~error() throw()
+    ~error() BOOST_QVM_NOEXCEPT
         {
         }
     };
