# to download new version:
# 0. go to https://github.com/ClickHouse/ClickHouse/releases
# 1. find desired version, let it be '23.11.5.29'
# 2a. for OS_LINUX run (change version to desired):
# version='23.11.5.29' && { curl -s -L "https://github.com/ClickHouse/ClickHouse/releases/download/v$version-stable/clickhouse-common-static-$version-amd64.tgz" | tar -zx --strip=3 "clickhouse-common-static-$version/usr/bin/clickhouse"; } && ya upload clickhouse --ttl=inf --tar -d "clickhouse $version binary linux"
# 2b. for OS_DARWIN run (change version to desired):
# version='23.11.5.29' && curl -s -L "https://github.com/ClickHouse/ClickHouse/releases/download/v$version-stable/clickhouse-macos" -o clickhouse && chmod u+x clickhouse && ./clickhouse local --version && ya upload clickhouse --ttl=inf --tar -d "clickhouse $version binary mac"
# note, mac binary MUST be run once, it's self-unpacking binary
# 3. add/update ELSEIF(CLICKHOUSE_VERSION == "23.11.5.29") section above

