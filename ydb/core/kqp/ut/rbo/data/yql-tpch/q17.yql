PRAGMA YqlSelect = 'force';
PRAGMA AnsiImplicitCrossJoin;

SELECT
    Sum(l_extendedprice) / $to_decimal_max_precision("7.0") AS avg_yearly
FROM
    `/Root/lineitem` as lineitem
,
    `/Root/part` as part
WHERE
    p_partkey == l_partkey
    AND p_brand == 'Brand#23'
    AND p_container == 'MED BOX'
    AND l_quantity < (
        SELECT
            $to_decimal("0.2") * Avg(l_quantity)
        FROM
            `/Root/lineitem` as lineitem
        WHERE
            l_partkey == p_partkey
    )
;
