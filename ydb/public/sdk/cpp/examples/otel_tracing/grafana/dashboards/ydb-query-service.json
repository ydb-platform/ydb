{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Request Rate by Operation",
      "type": "timeseries",
      "description": "Rate of finished operations per second, grouped by db.operation.name. Derived from db.client.operation.duration histogram observations (every End() increments _count).",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${prometheus_ds}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "sum by (db_operation_name) (rate(db_client_operation_duration_seconds_count[1m]))",
          "legendFormat": "{{db_operation_name}}"
        }
      ]
    },
    {
      "title": "Error Rate by Operation",
      "type": "timeseries",
      "description": "Rate of failed operations per second (db.client.operation.failed).",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${prometheus_ds}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 10 },
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "expr": "sum by (db_operation_name) (rate(db_client_operation_failed_total[1m]))",
          "legendFormat": "{{db_operation_name}}"
        }
      ]
    },
    {
      "title": "Duration p50 / p95 / p99 (s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${prometheus_ds}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 5 }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, db_operation_name) (rate(db_client_operation_duration_seconds_bucket[1m])))",
          "legendFormat": "p50 {{db_operation_name}}"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, db_operation_name) (rate(db_client_operation_duration_seconds_bucket[1m])))",
          "legendFormat": "p95 {{db_operation_name}}"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, db_operation_name) (rate(db_client_operation_duration_seconds_bucket[1m])))",
          "legendFormat": "p99 {{db_operation_name}}"
        }
      ]
    },
    {
      "title": "Error Ratio (%)",
      "type": "timeseries",
      "description": "failed / total per operation. Total is taken from db.client.operation.duration _count (one observation per finished call).",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${prometheus_ds}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": { "drawStyle": "line", "fillOpacity": 5 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum by (db_operation_name) (rate(db_client_operation_failed_total[5m])) / clamp_min(sum by (db_operation_name) (rate(db_client_operation_duration_seconds_count[5m])), 1e-9)",
          "legendFormat": "{{db_operation_name}}"
        }
      ]
    },
    {
      "title": "Connections by State",
      "type": "timeseries",
      "description": "db.client.connection.count split by db.client.connection.state (idle / used). For YDB session == connection.",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${prometheus_ds}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "fillOpacity": 30, "stacking": { "mode": "normal" } }
        }
      },
      "targets": [
        {
          "expr": "sum by (db_client_connection_pool_name, db_client_connection_state) (db_client_connection_count)",
          "legendFormat": "{{db_client_connection_pool_name}} / {{db_client_connection_state}}"
        }
      ]
    },
    {
      "title": "Pending Session Requests",
      "type": "timeseries",
      "description": "db.client.connection.pending_requests — current waiters for a session.",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${prometheus_ds}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "sum by (db_client_connection_pool_name) (db_client_connection_pending_requests)",
          "legendFormat": "{{db_client_connection_pool_name}}"
        }
      ]
    },
    {
      "title": "Session Acquire Timeouts /s",
      "type": "timeseries",
      "description": "db.client.connection.timeouts — rate of waiters whose deadline expired before a session was available.",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${prometheus_ds}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "sum by (db_client_connection_pool_name) (rate(db_client_connection_timeouts_total[1m]))",
          "legendFormat": "{{db_client_connection_pool_name}}"
        }
      ]
    },
    {
      "title": "Session Create Time p50 / p95 / p99 (s)",
      "type": "timeseries",
      "description": "db.client.connection.create_time — distribution of CreateSession latencies.",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${prometheus_ds}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 5 }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, db_client_connection_pool_name) (rate(db_client_connection_create_time_seconds_bucket[5m])))",
          "legendFormat": "p50 {{db_client_connection_pool_name}}"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, db_client_connection_pool_name) (rate(db_client_connection_create_time_seconds_bucket[5m])))",
          "legendFormat": "p95 {{db_client_connection_pool_name}}"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, db_client_connection_pool_name) (rate(db_client_connection_create_time_seconds_bucket[5m])))",
          "legendFormat": "p99 {{db_client_connection_pool_name}}"
        }
      ]
    },
    {
      "title": "Recent Traces",
      "type": "table",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 32 },
      "datasource": { "type": "jaeger", "uid": "${jaeger_ds}" },
      "targets": [
        {
          "query": "ydb-cpp-sdk-demo",
          "queryType": "search",
          "service": "ydb-cpp-sdk-demo"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "templating": {
    "list": [
      {
        "name": "prometheus_ds",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" }
      },
      {
        "name": "jaeger_ds",
        "type": "datasource",
        "query": "jaeger",
        "current": { "text": "Jaeger", "value": "Jaeger" }
      }
    ]
  },
  "time": { "from": "now-30m", "to": "now" },
  "title": "YDB QueryService",
  "uid": "ydb-query-service"
}
