$tupleVariantType = Variant<Int32, Int32>;

$data = [
    <|variantValue: Variant(1,  "0", $tupleVariantType)|>,
    <|variantValue: Variant(2,  "1", $tupleVariantType)|>,
    <|variantValue: Variant(42, "0", $tupleVariantType)|>,
];

SELECT Yql::VariantItem(variantValue) AS item FROM as_table($data);
