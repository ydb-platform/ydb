/* custom error: YqlSelect unsupported: Window function RowNumber */
PRAGMA YqlSelect = 'force';

-- FIXME(YQL-21046): bad test.
SELECT
    depname,
    empno,
    salary,
    enroll_date
FROM (
    SELECT
        depname,
        empno,
        salary,
        enroll_date,
        RowNumber() OVER (
            PARTITION BY
                depname
            ORDER BY
                salary DESC,
                empno
        ) AS pos
    FROM (
        VALUES
            ('develop', 11, 5200),
            ('develop', 7, 4200),
            ('develop', 9, 4500),
            ('develop', 8, 6000),
            ('develop', 10, 5200),
            ('personne', 5, 3500),
            ('personne', 2, 3900),
            ('sales', 3, 4800),
            ('sales', 1, 5000),
            ('sales', 4, 4800)
    ) AS empsalary (
        depname,
        empno,
        salary
    )
) AS ss
WHERE
    pos < 3
;
