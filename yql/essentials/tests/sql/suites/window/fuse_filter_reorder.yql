PRAGMA config.flags("OptimizerFlags", "PushdownFiltersOverWindow");

$src = select * from as_table([
<|key:1, subkey:1, a:3, b:4, c:5, d:6|>,
<|key:1, subkey:2, a:7, b:8, c:9, d:10|>,
<|key:2, subkey:1, a:11, b:12, c:13, d:14|>,
<|key:2, subkey:2, a:15, b:16, c:17, d:18|>,
<|key:3, subkey:1, a:19, b:20, c:21, d:22|>,
<|key:3, subkey:2, a:23, b:24, c:25, d:26|>,
]);

$src =
select t.*,
       agg_list(a) over w as list_a,
       max(b) over w1 as max_b
from $src as t
window
    w as (partition by key order by subkey),
    w1 as (partition by key order by subkey desc);

select t.*,
       min(c) over w1 as min_c,
       agg_list(d) over w as list_d,
from $src as t
where list_a[1] is not null or max_b < 100
window
    w1 as (partition by key order by subkey desc),
    w as (partition by key order by subkey);

