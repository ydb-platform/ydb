PRAGMA WindowNewPipeline;

$data = [
    <|a: NULL, b: 1, count: 2|>,
    <|a: NULL, b: 1, count: 2|>,
    <|a: 1000000p, b: 1, count: 1|>,
    <|a: 2000000p, b: 1, count: 1|>,
    <|a: 3000000p, b: 1, count: 1|>,
];

$win_result = SELECT
    COUNT(*) OVER w1 AS actual_count1,
    COUNT(*) OVER w2 AS actual_count2,
    COUNT(*) OVER w3 AS actual_count3,
    count as count,
FROM
    AS_TABLE($data)
WINDOW
    w1 AS (
        PARTITION COMPACT BY
            b
        ORDER BY
            a ASC
        RANGE BETWEEN pgfloat8('1.0') PRECEDING AND 0pn FOLLOWING
    ),
    w2 AS (
        PARTITION COMPACT BY
            b
        ORDER BY
            a ASC
        RANGE BETWEEN pgfloat8('3.0') PRECEDING AND 81p FOLLOWING
    ),
    w3 AS (
        PARTITION COMPACT BY
            b
        ORDER BY
            a ASC
        RANGE BETWEEN pgfloat4('1.0') PRECEDING AND 4p FOLLOWING
    );

SELECT
    Ensure(actual_count1, actual_count1 IS NOT DISTINCT FROM count),
    Ensure(actual_count2, actual_count2 IS NOT DISTINCT FROM count),
    Ensure(actual_count3, actual_count3 IS NOT DISTINCT FROM count)
FROM
    $win_result
;


