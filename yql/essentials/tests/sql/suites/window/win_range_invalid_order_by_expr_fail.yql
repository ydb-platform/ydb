PRAGMA WindowNewPipeline;

/* custom error: RANGE frame got error in ORDER BY expression */
/* custom error: Member not found: void */

$data = [
    <|a: "1", count: 1|>,
    <|a: "2", count: 1|>,
    <|a: "3", count: 1|>,
];

SELECT
    COUNT(*) OVER w1 AS actual_count,
    count,
FROM
    AS_TABLE($data)
WINDOW
    w1 AS (
        ORDER BY
            void ASC
        RANGE BETWEEN 1 PRECEDING AND 1 FOLLOWING
    )
