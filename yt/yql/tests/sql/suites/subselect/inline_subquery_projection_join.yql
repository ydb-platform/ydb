USE plato;

SELECT (SELECT Max(Input.key || Input2.subkey) FROM Input JOIN Input2 ON Input.subkey = Input2.key);

SELECT '1' || (SELECT Max(Input.key || Input2.subkey) FROM Input JOIN Input2 ON Input.subkey = Input2.key);

SELECT (SELECT Max(Input.key || Input2.subkey) FROM Input JOIN Input2 ON Input.subkey = Input2.key) || '1';

SELECT '1' || (SELECT Max(Input.key || Input2.subkey) FROM Input JOIN Input2 ON Input.subkey = Input2.key) || '1';
