use plato;
pragma AnsiInForEmptyOrNullableItemsCollections;
pragma yt.UseNativeYtTypes;
pragma yt.NativeYtTypeCompatibility="legacy";

insert into Output
select AddTimezone(CurrentUtcTimestamp(), "Europe/Moscow");
commit;

$src = select * from Output;
select AddTimezone(CurrentUtcTimestamp(), "Europe/Moscow") in compact $src from Input;

-- TODO remove this
commit;
insert into Output with truncate
select 1 limit 0;

