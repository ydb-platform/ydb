/* sort outputs */

use plato;

pragma Engine = "ytflow";

pragma Ytflow.Cluster = "plato";
pragma Ytflow.PipelinePath = "pipelines/test";

$input_stream = 
    select 
        key || "_before" as key_before,
        key,
        value
    from Input
    where value > 2;

$joined_stream =
    select 
        first_arg.key as key,
        first_arg.value as value,
        first_arg.key_before,
        second_arg.kv_value_a,
        third_arg.kv_value_b
    from $input_stream as first_arg
    inner join InputKeyValueTableA as second_arg
    on first_arg.key = second_arg.key
    inner join any InputKeyValueTableB as third_arg
    on second_arg.key = third_arg.key;

insert into Output
select 
    key,
    value,
    `first_arg.key_before` as key_before,
    key || "_after" as key_after,
    `second_arg.kv_value_a` as kv_value_a,
    `third_arg.kv_value_b` as kv_value_b
from $joined_stream
where value * 2 <= `third_arg.kv_value_b`;
