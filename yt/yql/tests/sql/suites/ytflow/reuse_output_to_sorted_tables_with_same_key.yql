/* sort outputs */

use plato;

pragma Engine = "ytflow";

pragma Ytflow.Cluster = "plato";
pragma Ytflow.PipelinePath = "pipelines/test";

$result_stream = select string_field as key, int64_field as value from Input;

insert into OutputFirst
select * from $result_stream;

insert into OutputSecond
select * from $result_stream;
